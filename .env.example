# Slack user token. Use a User OAuth Token that starts with xoxp-.
SLACK_USER_TOKEN=xoxp-your-token-here

# Output directory for JSON and TXT exports.
EXPORT_DIR=exports

# Slack API read settings.
PAGE_LIMIT=200
REQUEST_DELAY_SECONDS=0.8
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2

# Reserved for a later phase. Current exporter preserves file metadata only.
DOWNLOAD_FILES=false

# Google Chat incoming webhook URL for test imports.
GOOGLE_CHAT_WEBHOOK_URL=
